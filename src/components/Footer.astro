---
const year = 2026;
---
<footer>
  <div class="footer-inner">
    <p class="links">
      <a href="https://github.com/joaovorocha">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href="https://www.linkedin.com/in/victordorocha/">LinkedIn</a>
      <span aria-hidden="true">·</span>
      <a href="mailto:joaovorocha@gmail.com">Email</a>
    </p>
    <p class="copy">Copyright © {year} Joao V. Rocha. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--rule);
    background: var(--bg-elevated);
    margin-top: 6rem;
  }
  .footer-inner {
    max-width: var(--measure-wide);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--ink-faint);
  }
  .footer-inner p { color: inherit; margin: 0 0 0.5rem; font-size: inherit; line-height: 1.5; }
  .links a {
    color: var(--ink-soft);
    text-decoration: none;
    margin: 0 0.4rem;
  }
  .links a:first-of-type { margin-left: 0; }
  .links a:hover { color: var(--accent); text-decoration: underline; }
  .copy { color: var(--ink-faint); }
</style>
