---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChannelRail from '../components/ChannelRail.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  channel?: string;
  channelLabel?: string;
  channelColor?: 'cyan' | 'green' | 'red' | 'yellow' | 'magenta' | 'white';
  faderPosition?: string;
  ogImage?: string;
}

const {
  title,
  description,
  channel = '01',
  channelLabel = 'VICTOR ROCHA',
  channelColor = 'cyan',
  faderPosition = '36%',
  ogImage,
} = Astro.props;

const isHome = title === 'victorocha.com';
const fullTitle = isHome
  ? 'Joao V. Rocha — AV engineer & full-stack developer'
  : `${title} — victorocha.com`;
const desc = description ?? 'Joao V. Rocha — AV engineer, full-stack developer, Latin Grammy nominee. Based in San Francisco.';
const siteUrl = Astro.site ?? new URL('https://www.victorocha.com');
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage ?? '/og-default.png', siteUrl).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="theme-color" content="#0B0D0E" />

    <meta property="og:type" content={isHome ? 'website' : 'article'} />
    <meta property="og:site_name" content="victorocha.com" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <ChannelRail channel={channel} label={channelLabel} color={channelColor} faderPosition={faderPosition} />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-as-fader: bidirectional sync between page scroll and the
      // channel-rail fader cap. Drag the cap up/down to scroll. Click the
      // track to jump. Keyboard: focus the track and ↑/↓/PgUp/PgDn/Home/End.
      (() => {
        const rail = document.querySelector('.channel-rail');
        const track = rail?.querySelector<HTMLElement>('[data-fader-track]');
        const cap = rail?.querySelector<HTMLElement>('[data-fader-cap]');
        const readout = document.querySelector('.mb-readout');
        if (!rail || !track || !cap) return;

        // Wrap the REC indicator's right side with a live SCROLL% readout.
        if (readout && !readout.querySelector('.mb-pct')) {
          const span = document.createElement('span');
          span.className = 'mb-pct';
          span.style.marginLeft = '0.6rem';
          span.textContent = '· 00.0%';
          readout.appendChild(span);
        }
        const pctEl = document.querySelector<HTMLElement>('.mb-pct');

        const supportsScrollTimeline = CSS.supports?.('animation-timeline: scroll()');

        function scrollPct(): number {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          if (max <= 0) return 0;
          return Math.min(1, Math.max(0, window.scrollY / max));
        }

        function setCapFromScroll() {
          const p = scrollPct();
          if (!supportsScrollTimeline) cap.style.top = (p * 100) + '%';
          track.setAttribute('aria-valuenow', String(Math.round(p * 100)));
          if (pctEl) pctEl.textContent = '· ' + (p * 100).toFixed(1) + '%';
        }

        // Always update the readout (CSS handles the cap when supported)
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
              setCapFromScroll();
              ticking = false;
            });
          }
        }, { passive: true });
        setCapFromScroll();

        // Drag-to-scroll
        let dragging = false;
        let pointerId: number | null = null;

        function pointerDown(e: PointerEvent) {
          dragging = true;
          pointerId = e.pointerId;
          rail!.classList.add('is-dragging');
          (e.currentTarget as HTMLElement).setPointerCapture(e.pointerId);
          updateFromPointer(e);
        }
        function pointerMove(e: PointerEvent) {
          if (!dragging || e.pointerId !== pointerId) return;
          updateFromPointer(e);
        }
        function pointerUp(e: PointerEvent) {
          if (e.pointerId !== pointerId) return;
          dragging = false;
          pointerId = null;
          rail!.classList.remove('is-dragging');
        }
        function updateFromPointer(e: PointerEvent) {
          const rect = track!.getBoundingClientRect();
          const t = Math.min(1, Math.max(0, (e.clientY - rect.top) / rect.height));
          const max = document.documentElement.scrollHeight - window.innerHeight;
          window.scrollTo({ top: t * max, behavior: 'auto' });
          if (!supportsScrollTimeline) cap.style.top = (t * 100) + '%';
        }

        cap.addEventListener('pointerdown', pointerDown);
        cap.addEventListener('pointermove', pointerMove);
        cap.addEventListener('pointerup', pointerUp);
        cap.addEventListener('pointercancel', pointerUp);

        // Click anywhere on the track to jump
        track.addEventListener('click', (e) => {
          if (e.target === cap) return;
          const rect = track.getBoundingClientRect();
          const t = Math.min(1, Math.max(0, (e.clientY - rect.top) / rect.height));
          const max = document.documentElement.scrollHeight - window.innerHeight;
          window.scrollTo({ top: t * max, behavior: 'smooth' });
        });

        // Keyboard
        track.addEventListener('keydown', (e) => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          const step = window.innerHeight * 0.1;
          const page = window.innerHeight * 0.9;
          let target = window.scrollY;
          switch (e.key) {
            case 'ArrowDown': target += step; break;
            case 'ArrowUp':   target -= step; break;
            case 'PageDown':  target += page; break;
            case 'PageUp':    target -= page; break;
            case 'Home':      target = 0; break;
            case 'End':       target = max; break;
            default: return;
          }
          e.preventDefault();
          window.scrollTo({ top: Math.min(max, Math.max(0, target)), behavior: 'smooth' });
        });
      })();
    </script>
  </body>
</html>
