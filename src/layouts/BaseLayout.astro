---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  channel?: string;
  channelLabel?: string;
  channelColor?: 'cyan' | 'green' | 'red' | 'yellow' | 'magenta' | 'white';
  faderPosition?: string;
  ogImage?: string;
}

const {
  title,
  description,
  channel = '01',
  channelLabel = 'VICTOR ROCHA',
  channelColor = 'cyan',
  faderPosition = '36%',
  ogImage,
} = Astro.props;

const isHome = title === 'victorocha.com';
const fullTitle = isHome
  ? 'Joao V. Rocha — AV engineer & full-stack developer'
  : `${title} — victorocha.com`;
const desc = description ?? 'Joao V. Rocha — AV engineer, full-stack developer, Latin Grammy nominee. Based in San Francisco.';
const siteUrl = Astro.site ?? new URL('https://www.victorocha.com');
const canonical = new URL(Astro.url.pathname, siteUrl).toString();

// Per-page OG image discovery.
//
// Convention: scripts/gen-og-image.mjs --batch writes a card per content entry
// to /public/og/projects/<slug>.png and /public/og/writing/<slug>.png. If the
// caller didn't pass `ogImage` explicitly, derive a candidate from the URL
// pathname and check whether the file actually exists in /public — falling
// back to /og-default.png otherwise. This keeps the layout safe to deploy
// before postbuild runs and lets callers override either way.
import { existsSync } from 'node:fs';
import { join } from 'node:path';

function derivedOgPath(pathname: string): string | null {
  // /projects/shaddow  → /og/projects/shaddow.png
  // /writing/hello/    → /og/writing/hello.png
  const m = pathname.match(/^\/(projects|writing)\/([^\/]+)\/?$/);
  if (!m) return null;
  return `/og/${m[1]}/${m[2]}.png`;
}

function ogFileExists(publicPath: string): boolean {
  // Public assets live under <repo>/public mirroring the URL path.
  const fsPath = join(process.cwd(), 'public', publicPath.replace(/^\//, ''));
  try {
    return existsSync(fsPath);
  } catch {
    return false;
  }
}

let resolvedOgPath = ogImage;
if (!resolvedOgPath) {
  const candidate = derivedOgPath(Astro.url.pathname);
  resolvedOgPath = candidate && ogFileExists(candidate) ? candidate : '/og-default.png';
}
const ogImageUrl = new URL(resolvedOgPath, siteUrl).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="theme-color" content="#0B0D0E" />

    <meta property="og:type" content={isHome ? 'website' : 'article'} />
    <meta property="og:site_name" content="victorocha.com" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

  </body>
</html>
