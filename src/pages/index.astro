---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects', (p) => p.data.featured))
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('writing', (p) => !p.data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---
<BaseLayout
  title="victorocha.com"
  description="Joao V. Rocha — AV engineer at Clair Global, full-stack developer, Latin Grammy nominee. Building the tools I want to use, from San Francisco."
>
  <section class="hero">
    <p class="eyebrow">Joao V. Rocha · San Francisco</p>
    <h1>AV engineer.<br/>Full-stack developer.<br/><span class="accent">Latin Grammy nominee.</span></h1>
    <p class="lede">
      Currently mixing for Apple and Dolby with Sound Image (Clair Global), and shipping
      the software and hardware I think the operations floor is missing.
    </p>
    <p class="hire">
      <a href="/about#hire">Open to work →</a>
    </p>
  </section>

  <section class="projects-section">
    <p class="eyebrow center">Featured projects</p>
    <h2 class="section-title">What I'm building.</h2>
    <ul class="card-list">
      {featured.map((p) => (
        <li>
          <a class="card" href={`/projects/${p.id}`}>
            <h3>{p.data.title}</h3>
            <p>{p.data.summary}</p>
            <span class="meta">{p.data.status} · {p.data.tags.slice(0,3).join(' · ')}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="link-row"><a href="/projects">See all projects →</a></p>
  </section>

  <section class="writing-section">
    <p class="eyebrow center">Latest writing</p>
    <h2 class="section-title">Notes from the desk.</h2>
    {posts.length === 0 ? (
      <p class="meta center">Nothing published yet.</p>
    ) : (
      <ul class="card-list">
        {posts.map((p) => (
          <li>
            <a class="card" href={`/writing/${p.id}`}>
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
              <span class="meta">{fmt(p.data.publishedAt)}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
    <p class="link-row"><a href="/writing">All writing →</a></p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 6rem;
    padding-bottom: 6rem;
    text-align: center;
  }
  .hero h1 {
    font-size: clamp(2.5rem, 6vw + 1rem, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 1.02;
    max-width: 15ch;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 2rem;
  }
  .hero h1 .accent {
    background: linear-gradient(180deg, var(--accent), color-mix(in oklab, var(--accent) 70%, var(--ink) 30%));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .hero .lede {
    max-width: 36ch;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 2rem;
  }
  .hero .hire { margin-top: 2.5rem; font-size: 1.1rem; }
  .hero .hire a {
    display: inline-block;
    padding: 0.85rem 1.6rem;
    background: var(--accent);
    color: white;
    border-radius: 100px;
    font-family: var(--font-display);
    font-weight: 500;
    text-decoration: none;
    transition: background 150ms ease;
  }
  .hero .hire a:hover { background: var(--accent-hover); text-decoration: none; }

  .projects-section, .writing-section {
    padding-top: 5rem;
    padding-bottom: 2rem;
  }
  .eyebrow.center { text-align: center; color: var(--ink-faint); }
  .section-title {
    margin-top: 0;
    margin-bottom: 3rem;
    text-align: center;
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3rem);
    font-weight: 700;
    letter-spacing: -0.035em;
  }
  .link-row {
    text-align: center;
    margin-top: 2rem;
    font-size: 1rem;
    color: var(--accent);
  }
  .link-row a { font-weight: 500; }
  .meta.center { text-align: center; color: var(--ink-faint); }
</style>
