---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects', (p) => p.data.featured))
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('writing', (p) => !p.data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).toUpperCase();

const channelColor: Record<string, 'cyan' | 'green' | 'red' | 'yellow' | 'magenta' | 'white'> = {
  'shaddow': 'green',
  'live-audio': 'cyan',
  'van-conversion': 'magenta',
  'daily-ops-platform': 'green',
};
---
<BaseLayout
  title="victorocha.com"
  description="Joao V. Rocha — AV engineer at Clair Global, full-stack developer, Latin Grammy nominee. Building the tools I want to use, from San Francisco."
  channel="01"
  channelLabel="VICTOR ROCHA"
  channelColor="cyan"
  faderPosition="32%"
>
  <section class="hero">
    <video class="hero__bg" src="/video/brasilia-stage.mp4" poster="/video/brasilia-stage-poster.png"
           autoplay muted loop playsinline preload="metadata"></video>
    <div class="hero__scrim"></div>
    <header class="hero__chrome">
      <span>FIG. 01 · BRASÍLIA · 2017 · LATIN GRAMMY ERA</span>
      <span>SF · 37.7749 -122.4194</span>
    </header>
    <div class="hero__inner">
      <p class="eyebrow eyebrow--cyan">CH 01 · INPUT</p>
      <h1>Audio engineer.<br/>Latin Grammy nominee.<br/>Full-stack ops<span class="hero__caret">_</span></h1>
      <p class="hero__sub">
        A2 · Rock in Rio <span class="sep">/</span>
        AV for Apple &amp; Dolby <span class="sep">/</span>
        Node + Postgres in production
      </p>
    </div>
  </section>

  <section class="container">
    <header class="section-head">
      <p class="eyebrow eyebrow--cyan">02 · FEATURED PROJECTS</p>
      <h2>The bus stack.</h2>
    </header>
    <div class="channel-strips">
      {featured.map((p, i) => (
        <a
          class="channel-strip"
          href={`/projects/${p.id}`}
          data-color={channelColor[p.id] ?? 'cyan'}
        >
          <span class="channel-strip__color"></span>
          <div class="channel-strip__body">
            <div class="channel-strip__ch">
              CH 0{i + 2}
              <strong>{p.id.replace(/-/g, ' ').toUpperCase()}</strong>
            </div>
            <div class="channel-strip__meta">
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
            </div>
            <div class="channel-strip__send">
              {p.data.status} ·<br/>
              {p.data.tags.slice(0, 3).join(' / ')}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <figure class="photo full-bleed">
    <picture>
      <source type="image/webp" srcset="/images/live/venue-foh-1200.webp 1200w, /images/live/venue-foh-1600.webp 1600w" sizes="100vw" />
      <img src="/images/live/venue-foh-1200.jpg" srcset="/images/live/venue-foh-1200.jpg 1200w, /images/live/venue-foh-1600.jpg 1600w" sizes="100vw" alt="Avid VENUE console foreground with a Shure SM58 mid-frame and a magenta-lit worship stage with band silhouettes behind" width="1600" height="1067" loading="lazy" decoding="async" />
    </picture>
    <figcaption><span class="fig">FIG. 02 ·</span> FOH POSITION · BRAZIL · 2017 · BAND ▮ MAGENTA</figcaption>
  </figure>

  <section class="container">
    <header class="section-head">
      <p class="eyebrow eyebrow--white">03 · WRITING</p>
      <h2>Notes from the desk.</h2>
    </header>
    {posts.length === 0 ? (
      <p class="dim">[ EMPTY · NO POSTS PUBLISHED ]</p>
    ) : (
      <div class="channel-strips">
        {posts.map((p, i) => (
          <a class="channel-strip" data-color="white" href={`/writing/${p.id}`}>
            <span class="channel-strip__color"></span>
            <div class="channel-strip__body">
              <div class="channel-strip__ch">
                LOG 0{i + 1}<strong>WRITE</strong>
              </div>
              <div class="channel-strip__meta">
                <h3>{p.data.title}</h3>
                <p>{p.data.summary}</p>
              </div>
              <div class="channel-strip__send">{fmt(p.data.publishedAt)}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .section-head {
    margin: var(--chapter) 0 2.5rem;
  }
  .section-head h2 { margin: 0.5rem 0 0; }
</style>
