---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects', (p) => p.data.featured))
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('writing', (p) => !p.data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---
<BaseLayout title="victorocha.com">
  <section class="hero">
    <p class="meta">Joao V. Rocha · San Francisco</p>
    <h1>AV engineer and full-stack developer. Latin Grammy nominee. Builder of the tools I want to use.</h1>
    <p class="lede">
      Currently mixing for Apple and Dolby with <a href="https://www.soundimage.com">Sound Image</a>
      (Clair Global), and shipping the software and hardware I think the operations floor is
      missing. Ten-plus years of live audio behind me, a Node + Postgres stack in front of me,
      and Shaddow on the bench.
    </p>
    <p class="open-to">
      <span class="dot" aria-hidden="true"></span>
      Open to work — AV engineering, full-stack, or operations + technology roles.
      San Francisco / remote.
      <a href="/about#hire">Get in touch →</a>
    </p>
  </section>

  <hr />

  <section>
    <h2>Featured projects</h2>
    <ul class="card-list">
      {featured.map((p) => (
        <li>
          <a class="card" href={`/projects/${p.id}`}>
            <h3>{p.data.title}</h3>
            <p>{p.data.summary}</p>
            <span class="meta">
              {p.data.status}
              {p.data.tags.length > 0 && ' · '}
              {p.data.tags.join(' · ')}
            </span>
          </a>
        </li>
      ))}
    </ul>
    <p style="margin-top:1.25rem"><a href="/projects">All projects →</a></p>
  </section>

  <hr />

  <section>
    <h2>Latest writing</h2>
    {posts.length === 0 ? (
      <p class="meta">Nothing published yet.</p>
    ) : (
      <ul class="card-list">
        {posts.map((p) => (
          <li>
            <a class="card" href={`/writing/${p.id}`}>
              <h3>{p.data.title}</h3>
              <p>{p.data.summary}</p>
              <span class="meta">{fmt(p.data.publishedAt)}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
    <p style="margin-top:1.25rem"><a href="/writing">All writing →</a></p>
  </section>
</BaseLayout>

<style>
  .hero { padding-top: 1rem; }
  .hero h1 { font-size: 2.2rem; max-width: 30ch; margin-top: 0.6rem; }
  .lede { font-size: 1.1rem; color: var(--ink-soft); max-width: 52ch; }
  .open-to {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink-soft);
    background: var(--bg-elevated);
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 0.65rem 0.9rem;
    margin: 0.5rem 0 0;
  }
  .open-to a { white-space: nowrap; }
  .dot {
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
    flex-shrink: 0;
  }
</style>
