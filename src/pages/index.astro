---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignalFlow from '../components/SignalFlow.astro';
import VUMeter from '../components/VUMeter.astro';
import DigitalReadout from '../components/DigitalReadout.astro';
import { getCollection } from 'astro:content';

const featured = (await getCollection('projects', (p) => p.data.featured))
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('writing', (p) => !p.data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).toUpperCase();

const channelColor: Record<string, 'cyan' | 'green' | 'red' | 'yellow' | 'magenta' | 'white'> = {
  'shaddow': 'green',
  'live-audio': 'cyan',
  'daily-ops-platform': 'green',
};

// Per-project meter spec values
const channelSpec: Record<string, { value1: string; value2: string; level: number; meterColor: 'cyan' | 'green' | 'yellow' | 'red' | 'magenta' | 'white' }> = {
  'live-audio': {
    value1: '-18 dBFS',
    value2: '48 kHz / Dante',
    level: 68,
    meterColor: 'cyan',
  },
  'shaddow': {
    value1: 'MQTT bus',
    value2: 'iOS · Android',
    level: 62,
    meterColor: 'green',
  },
  'daily-ops-platform': {
    value1: '50+ daily users',
    value2: '<200 ms p95',
    level: 72,
    meterColor: 'green',
  },
};
---
<BaseLayout
  title="victorocha.com"
  description="Joao V. Rocha — AV engineer at Sound Image / Clair Global, full-stack developer, Latin Grammy nominee. Building the tools I want to use, from San Francisco."
  channel="01"
  channelLabel="VICTOR ROCHA"
  channelColor="cyan"
  faderPosition="32%"
>
  <section class="hero">
    <video class="hero__bg" src="/video/campinas-rgb.mp4" poster="/video/campinas-rgb-poster.png"
           autoplay muted loop playsinline preload="metadata"
           aria-label="RGB-lit foot controller in low light, Campinas, March 2020 — 18-second hero loop"></video>
    <div class="hero__scrim"></div>
    <header class="hero__chrome">
      <span>FIG. 01 · CAMPINAS · MARCH 2020 · 18s LOOP · RGB FOOT CONTROLLER</span>
      <span>SF · 37.7749 -122.4194</span>
    </header>
    <div class="hero__inner">
      <h1>Audio engineer.<br/>Latin Grammy nominee.<br/>Full-stack ops<span class="hero__caret">_</span></h1>
      <p class="hero__sub">
        A2 · Rock in Rio <span class="sep">/</span>
        AV for Apple &amp; Dolby <span class="sep">/</span>
        Node + Postgres in production
      </p>
    </div>
  </section>

  <SignalFlow variant="av-stack" />

  <section class="container">
    <header class="section-head">
      <p class="eyebrow eyebrow--cyan">02 · FEATURED PROJECTS</p>
      <h2>The bus stack.</h2>
    </header>
    <div class="channel-strips">
      {featured.map((p, i) => {
        const spec = channelSpec[p.id];
        return (
          <a
            class="channel-strip"
            href={`/projects/${p.id}`}
            data-color={channelColor[p.id] ?? 'cyan'}
          >
            <span class="channel-strip__color"></span>
            <div class="channel-strip__body">
              <div class="channel-strip__ch">
                <strong>{p.id.replace(/-/g, ' ').toUpperCase()}</strong>
              </div>
              <div class="channel-strip__meta">
                <h3>{p.data.title}</h3>
                <p>{p.data.summary}</p>
              </div>
              {spec && (
                <div class="channel-strip__meter">
                  <VUMeter level={spec.level} color={spec.meterColor} compact={true} scale="dB" />
                  <div class="channel-strip__readouts">
                    <DigitalReadout value={spec.value1} color={spec.meterColor === 'magenta' ? 'amber' : (spec.meterColor === 'green' ? 'green' : 'cyan')} width="7ch" size="sm" />
                    <DigitalReadout value={spec.value2} color={spec.meterColor === 'magenta' ? 'amber' : (spec.meterColor === 'green' ? 'green' : 'cyan')} width="7ch" size="sm" />
                  </div>
                </div>
              )}
              <div class="channel-strip__send">
                {p.data.status} ·<br/>
                {p.data.tags.slice(0, 3).join(' / ')}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <figure class="photo full-bleed">
    <picture>
      <source type="image/webp" srcset="/images/live/venue-foh-1200.webp 1200w, /images/live/venue-foh-1600.webp 1600w" sizes="100vw" />
      <img src="/images/live/venue-foh-1200.jpg" srcset="/images/live/venue-foh-1200.jpg 1200w, /images/live/venue-foh-1600.jpg 1600w" sizes="100vw" alt="Overhead view of an audio engineer mixing front-of-house at a compact digital console in a flight case, seated among wooden pews on a stone floor in a daylit Brazilian church" width="1600" height="1067" loading="lazy" decoding="async" />
    </picture>
    <figcaption><span class="fig">FIG. 02 ·</span> FOH POSITION · BRAZIL · 2017</figcaption>
  </figure>

  <section class="container">
    <header class="section-head">
      <p class="eyebrow eyebrow--white">03 · WRITING</p>
      <h2>Notes from the desk.</h2>
    </header>
    {posts.length === 0 ? (
      <p class="dim">[ EMPTY · NO POSTS PUBLISHED ]</p>
    ) : (
      <div class="channel-strips">
        {posts.map((p, i) => (
          <a class="channel-strip" data-color="white" href={`/writing/${p.id}`}>
            <span class="channel-strip__color"></span>
            <div class="channel-strip__body">
              <div class="channel-strip__ch">
                <strong>WRITE</strong>
              </div>
              <div class="channel-strip__meta">
                <h3>{p.data.title}</h3>
                <p>{p.data.summary}</p>
              </div>
              <div class="channel-strip__send">{fmt(p.data.publishedAt)}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .section-head {
    margin: var(--chapter) 0 2.5rem;
  }
  .section-head h2 { margin: 0.5rem 0 0; }

  /* Meter + readout sub-block in channel strips */
  .channel-strip__body {
    grid-template-columns: 90px 1fr auto auto;
  }
  .channel-strip__meter {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 0.5rem;
    border-left: 1px solid var(--console-rule);
    border-right: 1px solid var(--console-rule);
  }
  .channel-strip__readouts {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  @media (max-width: 720px) {
    .channel-strip__body {
      grid-template-columns: 1fr;
    }
    .channel-strip__meter {
      border-left: 0;
      border-right: 0;
      border-top: 1px solid var(--console-rule);
      border-bottom: 1px solid var(--console-rule);
      padding: 0.5rem 0;
    }
  }
</style>
