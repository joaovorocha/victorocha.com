---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.summary} narrow>
  <p class="meta back"><a href="/projects">← projects</a></p>
  <h1>{entry.data.title}</h1>
  <p class="lede">{entry.data.summary}</p>
  <p class="meta tags">
    <span>{entry.data.status}</span>
    {entry.data.tags.map((t) => <span class="tag">{t}</span>)}
    {entry.data.repo && <a href={entry.data.repo}>repo</a>}
    {entry.data.link && <a href={entry.data.link}>link</a>}
  </p>
  <hr />
  <article>
    <Content />
  </article>
</BaseLayout>

<style>
  .back { margin-bottom: 1.5rem; }
  .back a { color: var(--ink-soft); text-decoration: none; }
  .back a:hover { color: var(--accent); }
  .lede { font-size: 1.1rem; color: var(--ink-soft); }
  .tags { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; }
</style>
