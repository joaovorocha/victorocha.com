---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const channelMeta: Record<string, { ch: string; label: string; color: 'cyan' | 'green' | 'red' | 'yellow' | 'magenta' | 'white' }> = {
  'live-audio':           { ch: '02', label: 'LIVE AUDIO',  color: 'cyan' },
  'shaddow':              { ch: '03', label: 'SHADDOW',     color: 'green' },
  'daily-ops-platform':   { ch: '04', label: 'OPS PLATFORM', color: 'green' },
  'van-conversion':       { ch: '05', label: 'VAN BUILD',   color: 'magenta' },
};
const meta = channelMeta[entry.id] ?? { ch: '06', label: entry.id.toUpperCase(), color: 'cyan' };
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  channel={meta.ch}
  channelLabel={meta.label}
  channelColor={meta.color}
>
  <section class="container">
    <header class="project-head">
      <p class={`eyebrow eyebrow--${meta.color}`}>CH {meta.ch} · {meta.label}</p>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.summary}</p>
      <p class="tags">
        <span class="micro">STATUS · {entry.data.status}</span>
        {entry.data.tags.map((t) => <span class="tag">{t}</span>)}
        {entry.data.repo && <a class="ext" href={entry.data.repo}>→ REPO</a>}
        {entry.data.link && <a class="ext" href={entry.data.link}>→ VISIT</a>}
      </p>
    </header>
  </section>

  <article class="project-body">
    <Content />
  </article>
</BaseLayout>

<style>
  .project-head {
    margin: 3rem 0 var(--chapter);
    max-width: 22ch;
  }
  .project-head h1 { margin: 0.75rem 0 1.5rem; }
  .project-head .lede {
    color: var(--console-ink);
    font-size: 1.3rem;
    line-height: 1.4;
    max-width: 38ch;
    margin-bottom: 2rem;
  }
  .project-head .tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 0.4rem;
    margin: 0;
  }
  .project-head .ext {
    font-family: var(--f-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--cap-cyan);
    text-decoration: none;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--cap-cyan);
  }
  .project-body {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    font-size: 1.0625rem;
    line-height: 1.6;
  }
  .project-body :global(figure.photo.full-bleed) {
    margin-left: calc(50% - 50vw + var(--rail-w) / 2);
    margin-right: calc(50% - 50vw + var(--rail-w) / 2);
    max-width: none;
    width: auto;
  }
  @media (max-width: 720px) {
    .project-head { max-width: 100%; }
  }
</style>
