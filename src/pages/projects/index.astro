---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Projects"
  description="Projects Victor Rocha is building — Shaddow (12V automotive dock), Daily Operations Platform, live audio, the van."
>
  <h1>Projects</h1>
  <p class="lede">Things I'm building, in various states of done.</p>

  <ul class="card-list" style="margin-top: 2rem;">
    {projects.map((p) => (
      <li>
        <a class="card" href={`/projects/${p.id}`}>
          <h2>{p.data.title}</h2>
          <p>{p.data.summary}</p>
          <span class="meta">
            {p.data.status}
            {p.data.tags.length > 0 && ' · '}
            {p.data.tags.join(' · ')}
          </span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .lede { color: var(--ink-soft); }
</style>
