---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);

const channelColor: Record<string, 'cyan' | 'green' | 'red' | 'yellow' | 'magenta' | 'white'> = {
  'shaddow': 'green',
  'live-audio': 'cyan',
  'daily-ops-platform': 'green',
};
---
<BaseLayout
  title="Projects"
  description="Projects Victor Rocha is building — Shaddow (12V automotive dock), Daily Operations Platform, and a decade of live audio."
  channel="01"
  channelLabel="PROJECTS"
  channelColor="cyan"
>
  <section class="container">
    <header class="page-head">
      <p class="eyebrow eyebrow--cyan">01 · PROJECTS</p>
      <h1>The bus stack.</h1>
      <p class="dim">Each project is a channel on the mix. Hover to solo.</p>
    </header>

    <div class="channel-strips">
      {projects.map((p, i) => (
        <a
          class="channel-strip"
          href={`/projects/${p.id}`}
          data-color={channelColor[p.id] ?? 'cyan'}
        >
          <span class="channel-strip__color"></span>
          <div class="channel-strip__body">
            <div class="channel-strip__ch">
              CH 0{i + 1}
              <strong>{p.id.replace(/-/g, ' ').toUpperCase()}</strong>
            </div>
            <div class="channel-strip__meta">
              <h2>{p.data.title}</h2>
              <p>{p.data.summary}</p>
            </div>
            <div class="channel-strip__send">
              {p.data.status} ·<br/>
              {p.data.tags.slice(0, 3).join(' / ')}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { margin: 3rem 0 var(--chapter); }
  .page-head h1 { margin: 0.5rem 0 1rem; }
  .page-head p.dim { font-family: var(--f-mono); font-size: var(--fs-micro); letter-spacing: var(--tr-micro); text-transform: uppercase; }
</style>
