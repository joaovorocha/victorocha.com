---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', (p) => !p.data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).toUpperCase();
---
<BaseLayout
  title="Writing"
  description="Short essays on engineering decisions, live audio, and the trade-offs that don't make textbooks."
  channel="02"
  channelLabel="WRITING"
  channelColor="white"
>
  <section class="container">
    <header class="page-head">
      <p class="eyebrow">CH 02 · LOG</p>
      <h1>Notes from the desk.</h1>
      <p class="dim">Short essays on engineering, hardware, and the van.</p>
    </header>

    {posts.length === 0 ? (
      <p class="dim">[ EMPTY · NO POSTS PUBLISHED ]</p>
    ) : (
      <div class="channel-strips">
        {posts.map((p, i) => (
          <a class="channel-strip" data-color="white" href={`/writing/${p.id}`}>
            <span class="channel-strip__color"></span>
            <div class="channel-strip__body">
              <div class="channel-strip__ch">
                LOG {String(i + 1).padStart(2, '0')}<strong>WRITE</strong>
              </div>
              <div class="channel-strip__meta">
                <h2>{p.data.title}</h2>
                <p>{p.data.summary}</p>
              </div>
              <div class="channel-strip__send">{fmt(p.data.publishedAt)}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .page-head { margin: 3rem 0 var(--chapter); }
  .page-head h1 { margin: 0.5rem 0 1rem; }
  .page-head .dim { font-family: var(--f-mono); font-size: var(--fs-micro); letter-spacing: var(--tr-micro); text-transform: uppercase; }
</style>
